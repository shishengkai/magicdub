# 能力域 provider 选择
# provider key 使用 kebab-case；对应目录使用 snake_case。
MAGICDUB_ASSET_STORE_PROVIDER=fal-cdn
MAGICDUB_VOCAL_SEPARATION_PROVIDER=fal-sam-audio
MAGICDUB_ASR_PROVIDER=bailian-fun-asr
MAGICDUB_TTS_PROVIDER=fal-index-tts-2
MAGICDUB_LLM_PROVIDER=google-gemini

# CLI 默认目标语言（设置后可省略 --target-lang）
MAGICDUB_TARGET_LANG=en

# 工作区内 pipeline 自产音频的扩展名（默认 .wav；可选 .mp3 .m4a .aac .flac .ogg）
# MAGICDUB_PIPELINE_AUDIO_EXT=.wav

# 伴奏减法：instrumental ≈ source_audio − α * vocal_track
# MAGICDUB_VOCAL_SUBTRACT_ALPHA=0.98

# 成片混音时压低 instrumental 轨（可选，如 0.35 或 -6dB）
# MAGICDUB_RESIDUAL_MIX_VOLUME=
