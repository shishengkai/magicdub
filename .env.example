# Provider selection by capability
# 按能力域选择 provider
# Provider keys use kebab-case; matching directories use snake_case.
# provider key 使用 kebab-case；对应目录使用 snake_case。
MAGICDUB_ASSET_STORE_PROVIDER=fal-cdn
MAGICDUB_VOCAL_SEPARATION_PROVIDER=fal-sam-audio
MAGICDUB_ASR_PROVIDER=bailian-fun-asr
MAGICDUB_TTS_PROVIDER=fal-index-tts-2
MAGICDUB_LLM_PROVIDER=google-gemini

# Default CLI target language; when set, --target-lang can be omitted.
# CLI 默认目标语言；设置后可省略 --target-lang。
MAGICDUB_TARGET_LANG=en

# Extension for audio produced by the pipeline in task workspaces.
# 工作区内 pipeline 自产音频的扩展名。
# Default: .wav; options: .mp3 .m4a .aac .flac .ogg
# 默认 .wav；可选 .mp3 .m4a .aac .flac .ogg
# MAGICDUB_PIPELINE_AUDIO_EXT=.wav

# Instrumental subtraction: instrumental ~= source_audio - alpha * vocal_track
# 伴奏减法：instrumental ~= source_audio - alpha * vocal_track
# MAGICDUB_VOCAL_SUBTRACT_ALPHA=0.98

# Lower the instrumental track during final mix; optional, e.g. 0.35 or -6dB.
# 成片混音时压低 instrumental 轨；可选，如 0.35 或 -6dB。
# MAGICDUB_RESIDUAL_MIX_VOLUME=
